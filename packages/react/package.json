{
  "name": "@staffetta/react",
  "version": "0.2.0",
  "description": "React bindings for the staffetta speedtest client: a useSpeedtest hook with status, live log, start and cancel.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@staffetta/client": "workspace:^",
    "@staffetta/core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/staffetta/staffetta.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/staffetta/staffetta#readme",
  "bugs": "https://github.com/staffetta/staffetta/issues",
  "keywords": [
    "speedtest",
    "react",
    "hook",
    "bandwidth"
  ],
  "publishConfig": {
    "access": "public"
  }
}
