{
  "name": "@staffetta/server",
  "version": "0.1.0",
  "description": "Server side of the staffetta speedtest: stream primitives, a Web-standard fetch handler and a Node http adapter. Framework-agnostic.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "node --test --enable-source-maps './tests/**/*.test.ts'",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@staffetta/core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/staffetta/staffetta.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/staffetta/staffetta#readme",
  "bugs": "https://github.com/staffetta/staffetta/issues",
  "keywords": [
    "speedtest",
    "bandwidth",
    "server",
    "fetch-handler",
    "node"
  ],
  "publishConfig": {
    "access": "public"
  }
}
